<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("../partials/head") %>
</head>
<body>
  <%- include("../partials/header") %>

  <main class="container">
    <section class="hero">
      <h1><%= pageTitle %></h1>
      <p class="subtitle"><%= subtitle %></p>

      <div class="note">
        <form class="match-form">
          <label for="division">Division</label>
          <select id="division" name="division">
            <option>Women’s Doubles</option>
            <option>Men’s Doubles</option>
            <option>Mixed Doubles</option>
          </select>

          <label for="teamA">Your Team</label>
          <select id="teamA" name="teamA">
            <option>Pickle Queens</option>
            <option>Court Kings</option>
            <option>Mixed Magic</option>
          </select>

          <label for="teamB">Opponent Team</label>
          <select id="teamB" name="teamB">
            <option>Dink Girls</option>
            <option>Smash Bros</option>
            <option>Double Trouble</option>
          </select>

          <label for="matchDate">Requested Date and Time</label>
          <input id="matchDate" name="matchDate" type="datetime-local" />

          <button type="button" class="btn">Submit Request</button>
        </form>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
