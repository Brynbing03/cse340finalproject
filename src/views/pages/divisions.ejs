<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("../partials/head") %>
</head>
<body>
  <%- include("../partials/header") %>

  <main class="container">
    <section class="hero">
      <h1><%= pageTitle %></h1>
      <p class="subtitle"><%= subtitle %></p>

      <div class="card-grid">
        <article class="card">
          <h2>Women’s Doubles</h2>
          <p>Two female players per team.</p>
        </article>

        <article class="card">
          <h2>Men’s Doubles</h2>
          <p>Two male players per team.</p>
        </article>

        <article class="card">
          <h2>Mixed Doubles</h2>
          <p>One female player and one male player per team.</p>
        </article>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>
