<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <%- include("../partials/header") %>

  <main class="container">
    <section class="hero">
      <h1><%= title %></h1>
      <p class="subtitle">Choose a division to view teams and standings later.</p>

      <div class="card-grid">
        <% divisions.forEach(d => { %>
          <article class="card">
            <h2><%= d.name %></h2>
            <p>Division ID: <%= d.id %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>